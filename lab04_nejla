students = [
    {"name": "Amina", "year": 3, "email": "amina@untz.ba"},
    {"name": "Emir",  "year": 2, "email": "emir@untz.ba"},
    {"name": "Lejla", "year": 3, "email": "lejla@untz.ba"},
    {"name": "Samir", "year": 1, "email": "samir@untz.ba"}
]

def filter_by_year(students: list, year: int) -> list:                  #List comprehension — kompaktan način kreiranja nove liste. Čita se kao: "uzmi s za svaki s u students, ali samo ako je s["year"] == year"
    return [s for s in students if s["year"] == year]

def print_registry(students: list) -> None:
    print(f"{'Ime'} {'Email'}")                                     
    for s in students:
        print(f"{s['name']} {s['email']}")


print("~ Svi studenti ~")
print_registry(students)


print("\n~ Studenti 3. godine ~")
treca_godina = filter_by_year(students, 3)
print_registry(treca_godina)
